{
  "build": {
    "command": "bundle install && bundle exec jekyll build",
    "outputDirectory": "_site"
  },
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
